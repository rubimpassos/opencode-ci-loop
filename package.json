{
  "name": "opencode-ci-loop",
  "version": "0.4.1",
  "description": "opencode plugin: CI validation loop — watches GitHub Actions after a push, injects results into the session, with per-session toggle and a live SSE dashboard",
  "module": "index.ts",
  "main": "index.ts",
  "type": "module",
  "license": "MIT",
  "repository": "github:rubimpassos/opencode-ci-loop",
  "files": ["index.ts", "src", "!src/**/*.test.ts"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
